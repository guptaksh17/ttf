# PostgreSQL database connection URL
DATABASE_URL=postgresql://localhost:5432/taptoturf_dev

# Redis connection URL
REDIS_URL=redis://localhost:6379

# Express API server port
PORT=3000

# Write Batching settings for projection consumers (availability and history views)
# Controls the maximum size of buffered events before flushing to Postgres
PROJECTION_BATCH_SIZE=50

# Controls the maximum idle time (in milliseconds) before flushing buffered events to Postgres
PROJECTION_BATCH_TIMEOUT_MS=100

# Set to true to disable write batching and run projections in unbatched fallback mode
PROJECTION_DISABLE_BATCHING=false

# If true, projection and outbox containers tolerate Redis outages on startup and auto-reconnect later
IGNORE_REDIS_STARTUP_ERROR=false

# Test delay hook (in milliseconds) before committing reservations (for Chaos mid-transaction testing)
# Default is 0 (no delay)
TEST_ARTIFICIAL_DELAY_MS=0

# Set to true to disable the Transactional Outbox Relay background process inside the API server
# Default is false
DISABLE_OUTBOX_RELAY=false

